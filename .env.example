# Author Collaboration Tool - 环境变量模板
# 复制为 .env 后填入真实值:
#   cp .env.example .env

# AstrBot 与 napcat 之间的反向 WebSocket 共享 token。
# 在 napcat WebUI 的"网络配置 → 反向 WebSocket → access_token"里也要填一样的值。
# 建议用 openssl rand -hex 32 生成一个。
ONEBOT_ACCESS_TOKEN=replace-with-a-long-random-string

# 时区(也写进 docker-compose,但部分镜像也读这个)
TZ=Asia/Shanghai