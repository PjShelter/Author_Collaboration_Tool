# =============================================================================
# Secrets & credentials — NEVER commit
# =============================================================================

# .env holds ONEBOT_ACCESS_TOKEN shared between AstrBot and napcat.
# Keep .env.example (un-ignored below) as the safe template.
.env
.env.*
!.env.example

# napcat login QR code — anyone who scans it logs into the bot QQ account.
napcat-qrcode.png

# =============================================================================
# napcat runtime — regenerated by the napcat container on first launch
# =============================================================================
# napcat-config/ contains passkey.json and per-account bot state.
napcat-config/
napcat-logs/

# =============================================================================
# Vendored AstrBot upstream source (~62 MB)
# =============================================================================
# AstrBot is checked in wholesale so a fresh `git clone` is all you need.
# Runtime data under AstrBot/data/ is regenerated by the docker image on first
# boot and overwritten by the `./AstrBot/data:/AstrBot/data` bind mount, so it
# must stay untracked.
AstrBot/data/cmd_config.json
AstrBot/data/config/
AstrBot/data/data_v4.db
AstrBot/data/data_v4.db-journal
AstrBot/data/data_v4.db-shm
AstrBot/data/data_v4.db-wal
AstrBot/data/dashboard.zip
AstrBot/data/dist/
AstrBot/data/knowledge_base/
AstrBot/data/mcp_server.json
AstrBot/data/plugins.json
AstrBot/data/site-packages/
AstrBot/data/skills/
AstrBot/data/skills.json
AstrBot/data/t2i_templates/
AstrBot/data/temp/
AstrBot/data/webchat/
AstrBot/data/attachments/

# =============================================================================
# Plugin runtime data — regenerated by the bot at runtime
# =============================================================================
AstrBot/data/plugins/author_collaboration/data/*.db
AstrBot/data/plugins/author_collaboration/data/*.db-journal
AstrBot/data/plugins/author_collaboration/data/*.db-wal
AstrBot/data/plugins/author_collaboration/data/*.db-shm
AstrBot/data/plugins/author_collaboration/data/*.yaml.bak
AstrBot/data/plugins/author_collaboration/data/live2d_packages/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# =============================================================================
# Claude Code local state (per-machine, never share)
# =============================================================================
.claude/

# =============================================================================
# Logs
# =============================================================================
*.log
logs/

# =============================================================================
# IDE / OS
# =============================================================================
.vscode/
.idea/
.DS_Store
*.swp
*.swo
Thumbs.db